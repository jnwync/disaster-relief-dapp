# RPC endpoint for Sepolia testnet (e.g., Alchemy or Infura)
SEPOLIA_RPC_URL=https://sepolia.infura.io/v3/YOUR_PROJECT_ID

# Private key of deploying wallet (DO NOT commit real keys)
DEPLOYER_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# Three validator addresses for multi-sig (public addresses)
VALIDATOR_1=0xVALIDATOR_1_ADDRESS
VALIDATOR_2=0xVALIDATOR_2_ADDRESS
VALIDATOR_3=0xVALIDATOR_3_ADDRESS
